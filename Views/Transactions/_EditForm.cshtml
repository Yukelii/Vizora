@model Vizora.Models.TransactionUpsertViewModel
@using System.Text.Json

@{
    var categoryTypeMapJson = JsonSerializer.Serialize(ViewData["CategoryTypeMap"] ?? new Dictionary<int, string>());
}

<form asp-action="Edit" method="post" data-modal-form="edit-transaction">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="RowVersion" />

    <div class="mb-3">
        <label asp-for="TransactionDate" class="form-label"></label>
        <input asp-for="TransactionDate" class="form-control" type="date" />
        <span asp-validation-for="TransactionDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CategoryId" class="form-label"></label>
        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId">
            <option value="">-- Select Category --</option>
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
        <div id="derivedTypeContainer" class="mt-2 d-none">
            <span class="me-2">Type:</span>
            <span id="derivedTypeBadge" class="badge"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Amount" class="form-label"></label>
        <input asp-for="Amount" class="form-control" step="0.01" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <input type="hidden" id="CategoryTypeMapJson" value='@categoryTypeMapJson' />

    <div class="d-flex flex-wrap gap-2">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-outline-secondary" data-modal-close="true">Cancel</a>
    </div>
</form>
