@model Vizora.Models.TransactionsIndexViewModel

@{
    ViewData["Title"] = "Transactions";
    var transactions = Model.Transactions?.ToList() ?? new List<Vizora.Models.Transaction>();
    var startDateValue = Model.StartDate?.ToString("yyyy-MM-dd");
    var endDateValue = Model.EndDate?.ToString("yyyy-MM-dd");
    var minAmountValue = Model.MinAmount?.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
    var maxAmountValue = Model.MaxAmount?.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
    var firstRecord = Model.TotalCount > 0
        ? ((Model.Page - 1) * Model.PageSize) + 1
        : 0;
    var lastRecord = Model.TotalCount > 0
        ? Math.Min(Model.Page * Model.PageSize, Model.TotalCount)
        : 0;
}

<section class="vz-content vz-trx-page">
    <header class="vz-content-header vz-trx-header">
        <div class="vz-trx-title-block">
            <h1>Transactions</h1>
            <p class="vz-trx-subtitle">Manage your financial flow and categorized records.</p>
        </div>
        <a asp-action="Create"
           class="btn btn-primary vz-trx-add-btn"
           data-modal="true"
           data-modal-title="Add Transaction">
            <span class="vz-trx-add-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M12 5v14"></path>
                    <path d="M5 12h14"></path>
                </svg>
            </span>
            <span>Add Transaction</span>
        </a>
    </header>

    <section class="vz-trx-toolbar-surface vz-panel">
        <form class="vz-trx-toolbar" method="get" asp-action="Index">
            <div class="vz-trx-search-field">
                <label for="transactionSearch" class="visually-hidden">Search transactions</label>
                <span class="vz-trx-search-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <circle cx="11" cy="11" r="7"></circle>
                        <path d="M20 20l-3.4-3.4"></path>
                    </svg>
                </span>
                <input id="transactionSearch"
                       name="search"
                       type="search"
                       class="form-control"
                       value="@Model.Search"
                       placeholder="Search transactions, amounts, or categories..." />
            </div>

            <div class="vz-trx-toolbar-grid">
                <div class="vz-filter-field">
                    <label for="startDate" class="form-label">Date From</label>
                    <input id="startDate" name="startDate" type="date" class="form-control" value="@startDateValue" />
                </div>

                <div class="vz-filter-field">
                    <label for="endDate" class="form-label">Date To</label>
                    <input id="endDate" name="endDate" type="date" class="form-control" value="@endDateValue" />
                </div>

                <div class="vz-filter-field">
                    <label for="categoryFilter" class="form-label">Category</label>
                    <select id="categoryFilter" name="category" class="form-select">
                        <option value="">All Categories</option>
                        @foreach (var category in Model.CategoryOptions)
                        {
                            <option value="@category.Id" selected="@(Model.Category == category.Id)">
                                @category.Name
                            </option>
                        }
                    </select>
                </div>

                <div class="vz-trx-segment-wrap">
                    <span class="vz-trx-segment-label">Type</span>
                    <div class="vz-trx-segmented" role="group" aria-label="Transaction type filter">
                        <button type="button" class="vz-trx-segment is-active" aria-pressed="true">All</button>
                        <button type="button"
                                class="vz-trx-segment"
                                disabled
                                aria-disabled="true"
                                title="Income toggle is a visual placeholder. Type filtering is not supported by the current backend query.">
                            Income
                        </button>
                        <button type="button"
                                class="vz-trx-segment"
                                disabled
                                aria-disabled="true"
                                title="Expense toggle is a visual placeholder. Type filtering is not supported by the current backend query.">
                            Expenses
                        </button>
                    </div>
                </div>
            </div>

            <div class="vz-trx-toolbar-grid vz-trx-secondary-grid">
                <div class="vz-filter-field">
                    <label for="minAmount" class="form-label">Min Amount</label>
                    <input id="minAmount"
                           name="minAmount"
                           type="number"
                           min="0.01"
                           step="0.01"
                           class="form-control"
                           value="@minAmountValue" />
                </div>

                <div class="vz-filter-field">
                    <label for="maxAmount" class="form-label">Max Amount</label>
                    <input id="maxAmount"
                           name="maxAmount"
                           type="number"
                           min="0.01"
                           step="0.01"
                           class="form-control"
                           value="@maxAmountValue" />
                </div>

                <div class="vz-filter-field">
                    <label for="pageSize" class="form-label">Rows Per Page</label>
                    <select id="pageSize" name="pageSize" class="form-select">
                        <option value="20" selected="@(Model.PageSize == 20)">20</option>
                        <option value="50" selected="@(Model.PageSize == 50)">50</option>
                        <option value="100" selected="@(Model.PageSize == 100)">100</option>
                    </select>
                </div>

                <div class="vz-filter-actions vz-trx-toolbar-actions">
                    <button type="submit" class="btn btn-primary">Apply</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
                </div>
            </div>

            <input type="hidden" name="page" value="1" />
        </form>
    </section>

    @if (!ViewData.ModelState.IsValid)
    {
        <section class="vz-panel">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        </section>
    }

    <section class="vz-trx-table-card">
        <div class="table-responsive">
            <table class="table align-middle mb-0 vz-trx-table">
                <thead>
                    <tr>
                        <th scope="col">Date</th>
                        <th scope="col">Description</th>
                        <th scope="col">Category</th>
                        <th scope="col">Type</th>
                        <th scope="col" class="text-end">Amount</th>
                        <th scope="col" class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (transactions.Any())
                    {
                        foreach (var item in transactions)
                        {
                            var descriptionText = string.IsNullOrWhiteSpace(item.Description) ? "-" : item.Description;
                            var categoryName = string.IsNullOrWhiteSpace(item.Category?.Name)
                                ? "Uncategorized"
                                : item.Category!.Name;
                            var isIncome = item.Type == TransactionType.Income;
                            var categoryIconKey = CategoryVisualCatalog.ResolveIconKeyOrDefault(item.Category?.IconKey);
                            var categoryColorKey = CategoryVisualCatalog.ResolveColorKeyOrDefault(item.Category?.ColorKey);
                            var amountClass = isIncome ? "vz-trx-amount-income" : "vz-trx-amount-expense";
                            var typeClass = isIncome ? "vz-trx-chip-income" : "vz-trx-chip-expense";
                            <tr class="vz-trx-row">
                                <td class="vz-trx-date">@item.TransactionDate.ToString("MMM dd, yyyy")</td>
                                <td class="vz-trx-description-cell">
                                    <span class="vz-trx-description" title="@descriptionText">@descriptionText</span>
                                </td>
                                <td>
                                    <span class="vz-trx-chip vz-trx-chip-category vz-cat-color-@categoryColorKey">
                                        <partial name="~/Views/Categories/_CategoryIconSvg.cshtml" model="categoryIconKey" />
                                        @categoryName
                                    </span>
                                </td>
                                <td>
                                    <span class="vz-trx-chip @typeClass">
                                        <span class="vz-trx-type-dot" aria-hidden="true"></span>
                                        @item.Type
                                    </span>
                                </td>
                                <td class="text-end">
                                    <span class="vz-trx-amount @amountClass">
                                        @(isIncome ? "+" : "-")PHP @item.Amount.ToString("N2")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <div class="vz-action-icons vz-trx-row-actions" aria-label="Transaction actions">
                                        <a asp-action="Details"
                                           asp-route-id="@item.Id"
                                           data-modal="true"
                                           data-modal-title="Transaction Details"
                                           class="vz-action-icon vz-action-view"
                                           title="Details"
                                           aria-label="View details">
                                            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                                <path d="M12 12m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0"></path>
                                                <path d="M22 12c-2 3.5 -5 5 -10 5s-8 -1.5 -10 -5c2 -3.5 5 -5 10 -5s8 1.5 10 5"></path>
                                            </svg>
                                        </a>
                                        <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           data-modal="true"
                                           data-modal-title="Edit Transaction"
                                           class="vz-action-icon vz-action-edit"
                                           title="Edit"
                                           aria-label="Edit transaction">
                                            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                                <path d="M7 20h4l10 -10a2.828 2.828 0 0 0 -4 -4l-10 10v4"></path>
                                                <path d="M16 7l3 3"></path>
                                            </svg>
                                        </a>
                                        <a asp-action="Delete"
                                           asp-route-id="@item.Id"
                                           data-modal="true"
                                           data-modal-title="Delete Transaction"
                                           class="vz-action-icon vz-action-delete"
                                           title="Delete"
                                           aria-label="Delete transaction">
                                            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                                <path d="M4 7h16"></path>
                                                <path d="M10 11v6"></path>
                                                <path d="M14 11v6"></path>
                                                <path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12"></path>
                                                <path d="M9 7l1 -3h4l1 3"></path>
                                            </svg>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                No transactions found for the selected filters.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalCount > 0)
        {
            <footer class="vz-trx-pagination-footer">
                <p class="vz-trx-pagination-summary">
                    Showing <strong>@firstRecord</strong> to <strong>@lastRecord</strong> of <strong>@Model.TotalCount</strong> results
                </p>
                <div class="vz-trx-pagination-controls">
                    <span class="vz-trx-pagination-page">Page @Model.Page of @Model.TotalPages</span>
                    @if (Model.HasPreviousPage)
                    {
                        <a asp-action="Index"
                           asp-route-page="@(Model.Page - 1)"
                           asp-route-pageSize="@Model.PageSize"
                           asp-route-search="@Model.Search"
                           asp-route-category="@Model.Category"
                           asp-route-startDate="@startDateValue"
                           asp-route-endDate="@endDateValue"
                           asp-route-minAmount="@minAmountValue"
                           asp-route-maxAmount="@maxAmountValue"
                           class="btn btn-outline-secondary btn-sm">Previous</a>
                    }
                    else
                    {
                        <button type="button" class="btn btn-outline-secondary btn-sm" disabled>Previous</button>
                    }

                    @if (Model.HasNextPage)
                    {
                        <a asp-action="Index"
                           asp-route-page="@(Model.Page + 1)"
                           asp-route-pageSize="@Model.PageSize"
                           asp-route-search="@Model.Search"
                           asp-route-category="@Model.Category"
                           asp-route-startDate="@startDateValue"
                           asp-route-endDate="@endDateValue"
                           asp-route-minAmount="@minAmountValue"
                           asp-route-maxAmount="@maxAmountValue"
                                   class="btn btn-outline-secondary btn-sm">Next</a>
                    }
                    else
                    {
                        <button type="button" class="btn btn-outline-secondary btn-sm" disabled>Next</button>
                    }
                </div>
            </footer>
        }
    </section>
</section>
