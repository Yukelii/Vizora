@model Vizora.Models.TransactionUpsertViewModel

@{
    ViewData["Title"] = "Edit Transaction";
    var isModalRequest = string.Equals(
        Context.Request.Headers["X-Requested-With"],
        "XMLHttpRequest",
        StringComparison.OrdinalIgnoreCase);

    if (isModalRequest)
    {
        Layout = null;
    }
}

@if (isModalRequest)
{
    @await Html.PartialAsync(
        "~/Views/Shared/_Modal.cshtml",
        new Dictionary<string, object?>
        {
            ["Size"] = "md",
            ["Variant"] = "form",
            ["BodyPartial"] = "~/Views/Transactions/_EditForm.cshtml",
            ["BodyModel"] = Model,
            ["State"] = ViewData["ModalState"]?.ToString() ?? "idle"
        })
}
else
{
    <h1>Edit Transaction</h1>

    <hr />
    <div class="row">
        <div class="col-md-6">
            <partial name="_EditForm" model="Model" />
            <div class="mt-3">
                <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
            </div>
        </div>
    </div>
}
