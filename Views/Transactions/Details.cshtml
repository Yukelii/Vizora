@model Vizora.Models.Transaction

@{
    ViewData["Title"] = "Transaction Details";
    var isModalRequest = string.Equals(
        Context.Request.Headers["X-Requested-With"],
        "XMLHttpRequest",
        StringComparison.OrdinalIgnoreCase);

    if (isModalRequest)
    {
        Layout = null;
    }
}

@if (isModalRequest)
{
    @await Html.PartialAsync(
        "~/Views/Shared/_Modal.cshtml",
        new Dictionary<string, object?>
        {
            ["Size"] = "md",
            ["Variant"] = "details",
            ["BodyPartial"] = "~/Views/Transactions/_DetailsModal.cshtml",
            ["BodyModel"] = Model
        })
}
else
{
    <h1>Transaction Details</h1>

    <hr />
    <div class="row">
        <div class="col-md-7">
            <partial name="_DetailsModal" model="Model" />
            <div class="mt-3">
                <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
            </div>
        </div>
    </div>
}
