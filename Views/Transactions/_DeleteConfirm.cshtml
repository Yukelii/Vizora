@model Vizora.Models.Transaction

@{
    var categoryName = Model.Category?.Name ?? "Uncategorized";
    var titleText = string.IsNullOrWhiteSpace(Model.Description) ? categoryName : Model.Description;
    var summaryText = $"{categoryName} - {Model.TransactionDate:yyyy-MM-dd} - PHP {Model.Amount:N2}";
    var typeBadgeClass = Model.Type == TransactionType.Income ? "vz-cat-badge-income" : "vz-cat-badge-expense";
}

<div class="vz-modal-delete">
    <p class="vz-modal-delete-lead">Are you sure you want to delete this transaction?</p>

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="vz-modal-delete-summary" role="group" aria-label="Transaction summary">
        <div class="vz-modal-delete-meta">
            <p class="vz-modal-delete-label">Transaction Name</p>
            <p class="vz-modal-delete-value">@titleText</p>
            <p class="vz-modal-delete-subvalue">@summaryText</p>
        </div>
        <span class="vz-cat-badge @typeBadgeClass">@Model.Type</span>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex flex-wrap gap-2 justify-content-end vz-modal-delete-actions">
            <a asp-action="Index" class="btn btn-outline-secondary" data-modal-close="true">Cancel</a>
            <button type="submit" class="btn btn-danger">Delete</button>
        </div>
    </form>
</div>
