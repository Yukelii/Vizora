@model Vizora.Models.Transaction

@{
    var categoryName = Model.Category?.Name ?? "Uncategorized";
    var titleText = string.IsNullOrWhiteSpace(Model.Description) ? categoryName : Model.Description;
    var iconKey = CategoryVisualCatalog.ResolveIconKeyOrDefault(Model.Category?.IconKey);
    var colorKey = CategoryVisualCatalog.ResolveColorKeyOrDefault(Model.Category?.ColorKey);
    var typeBadgeClass = Model.Type == TransactionType.Income ? "vz-cat-badge-income" : "vz-cat-badge-expense";
}

<div class="vz-modal-details">
    <div class="vz-modal-details-head">
        <span class="vz-cat-icon-tile vz-cat-color-@colorKey" aria-hidden="true">
            <partial name="~/Views/Categories/_CategoryIconSvg.cshtml" model="iconKey" />
        </span>
        <div class="vz-modal-details-title-wrap">
            <p class="vz-modal-details-title">@titleText</p>
            <p class="vz-modal-details-subtitle">@categoryName - @Model.TransactionDate.ToString("yyyy-MM-dd")</p>
        </div>
        <span class="vz-cat-badge @typeBadgeClass">@Model.Type</span>
    </div>

    <div class="vz-modal-details-grid" role="group" aria-label="Transaction details">
        <div class="vz-modal-details-item">
            <span class="vz-modal-details-label">Amount</span>
            <span class="vz-modal-details-value">PHP @Model.Amount.ToString("N2")</span>
        </div>
        <div class="vz-modal-details-item">
            <span class="vz-modal-details-label">Category</span>
            <span class="vz-modal-details-value">@categoryName</span>
        </div>
        <div class="vz-modal-details-item">
            <span class="vz-modal-details-label">Created</span>
            <span class="vz-modal-details-value">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span>
        </div>
        <div class="vz-modal-details-item">
            <span class="vz-modal-details-label">Updated</span>
            <span class="vz-modal-details-value">@Model.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</span>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2 vz-modal-details-actions">
        <a asp-action="Edit"
           asp-route-id="@Model.Id"
           class="btn btn-primary"
           data-modal="true"
           data-modal-title="Edit Transaction">Edit</a>
        <button type="button" class="btn btn-outline-secondary" data-modal-close="true">Close</button>
    </div>
</div>
