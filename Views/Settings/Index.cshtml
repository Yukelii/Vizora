@{
    ViewData["Title"] = "Settings";
}

<h1 class="mb-2">Account Settings</h1>
<p class="text-muted mb-4">Settings route placeholder. Use this page for profile and preference management.</p>

<div class="card">
    <div class="card-body">
        <h2 class="h5 mb-2">Change Password</h2>
        <p class="text-muted mb-3">
            Password management is currently handled in the secure change password form.
        </p>
        <a asp-controller="Auth" asp-action="ChangePassword" class="btn btn-primary">Open Change Password</a>
    </div>
</div>
