@model Vizora.Models.ModalErrorViewModel

<div class="alert alert-danger mb-3" role="alert">
    @Model.Message
</div>
<div class="d-flex flex-wrap gap-2 justify-content-end">
    <button type="button" class="btn btn-outline-secondary" data-modal-close="true">Close</button>
    <button type="button" class="btn btn-outline-primary" data-vz-modal-reload-page="true">Reload Page</button>
</div>
