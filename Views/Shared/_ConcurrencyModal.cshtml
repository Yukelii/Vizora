@model Vizora.Models.ConcurrencyModalViewModel

<div class="vz-concurrency-modal">
    <h3 class="vz-concurrency-title">Conflict Detected</h3>
    <p class="vz-concurrency-message">This @Model.EntityName was modified while you were editing.</p>

    <div class="vz-concurrency-table-wrap" role="region" aria-label="Conflict comparison">
        <table class="table table-sm align-middle mb-0 vz-concurrency-table">
            <thead>
                <tr>
                    <th scope="col">Field</th>
                    <th scope="col">Your Changes</th>
                    <th scope="col">Current Data</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.FieldComparisons)
                {
                    <tr>
                        <th scope="row">@row.FieldLabel</th>
                        <td>@row.YourValue</td>
                        <td>@row.LatestValue</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex flex-wrap gap-2 justify-content-end vz-concurrency-actions">
        <a href="@Model.ReloadUrl"
           class="btn btn-outline-secondary"
           data-modal="true"
           data-modal-title="@Model.ReloadModalTitle">Reload Latest</a>

        <form method="post" action="@Model.OverwriteActionUrl" class="d-inline-flex">
            @Html.AntiForgeryToken()
            @foreach (var field in Model.HiddenFields)
            {
                <input type="hidden" name="@field.Key" value="@field.Value" />
            }
            <button type="submit" class="btn btn-primary">@Model.OverwriteButtonLabel</button>
        </form>

        <button type="button" class="btn btn-outline-secondary" data-modal-close="true">Cancel</button>
    </div>
</div>
