@model Vizora.Models.BudgetPerformanceViewModel

<div class="vz-modal-delete">
    <p class="vz-modal-delete-lead">Are you sure you want to delete this budget?</p>

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="vz-modal-delete-summary" role="group" aria-label="Budget summary">
        <div class="vz-modal-delete-meta">
            <p class="vz-modal-delete-label">Budget Name</p>
            <p class="vz-modal-delete-value">@Model.CategoryName</p>
            <p class="vz-modal-delete-subvalue">
                @Model.StartDate.ToString("yyyy-MM-dd") - @Model.EndDate.ToString("yyyy-MM-dd")
                - Planned PHP @Model.PlannedAmount.ToString("N2")
            </p>
        </div>
        <span class="badge text-bg-secondary">@Model.PeriodType</span>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" name="id" value="@Model.BudgetId" />
        <div class="d-flex flex-wrap gap-2 justify-content-end vz-modal-delete-actions">
            <a asp-action="Index" class="btn btn-outline-secondary" data-modal-close="true">Cancel</a>
            <button type="submit" class="btn btn-danger">Delete</button>
        </div>
    </form>
</div>
