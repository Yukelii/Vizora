@model Vizora.Models.BudgetPerformanceViewModel

@{
    var remainingClass = Model.RemainingAmount >= 0 ? "is-positive" : "is-negative";
    var statusClass = Model.IsOverBudget ? "text-bg-danger" : "text-bg-success";
    var statusText = Model.IsOverBudget ? "Over Budget" : "Within Budget";
}

<div class="vz-modal-details">
    <div class="vz-modal-details-head">
        <span class="vz-modal-details-icon" aria-hidden="true">B</span>
        <div class="vz-modal-details-title-wrap">
            <p class="vz-modal-details-title">@Model.CategoryName</p>
            <p class="vz-modal-details-subtitle">
                @Model.StartDate.ToString("yyyy-MM-dd") - @Model.EndDate.ToString("yyyy-MM-dd")
            </p>
        </div>
        <span class="badge @statusClass">@statusText</span>
    </div>

    <div class="vz-modal-details-grid" role="group" aria-label="Budget details">
        <div class="vz-modal-details-item">
            <span class="vz-modal-details-label">Type</span>
            <span class="vz-modal-details-value">@Model.PeriodType</span>
        </div>
        <div class="vz-modal-details-item">
            <span class="vz-modal-details-label">Planned</span>
            <span class="vz-modal-details-value">PHP @Model.PlannedAmount.ToString("N2")</span>
        </div>
        <div class="vz-modal-details-item">
            <span class="vz-modal-details-label">Actual</span>
            <span class="vz-modal-details-value">PHP @Model.ActualSpending.ToString("N2")</span>
        </div>
        <div class="vz-modal-details-item">
            <span class="vz-modal-details-label">Remaining</span>
            <span class="vz-modal-details-value @remainingClass">PHP @Model.RemainingAmount.ToString("N2")</span>
        </div>
        <div class="vz-modal-details-item">
            <span class="vz-modal-details-label">Usage</span>
            <span class="vz-modal-details-value">@Model.UsagePercent.ToString("N2")%</span>
        </div>
        <div class="vz-modal-details-item">
            <span class="vz-modal-details-label">Status</span>
            <span class="vz-modal-details-value">@statusText</span>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2 vz-modal-details-actions">
        <a asp-action="Edit"
           asp-route-id="@Model.BudgetId"
           class="btn btn-primary"
           data-modal="true"
           data-modal-title="Edit Budget">Edit</a>
        <button type="button" class="btn btn-outline-secondary" data-modal-close="true">Close</button>
    </div>
</div>
