@model Vizora.Models.ReportsIndexViewModel
@using Vizora.DTOs

@{
    ViewData["Title"] = "Reports";
}

<section class="vz-content">
    <header class="vz-content-header">
        <div>
            <p class="vz-content-kicker">Data Tools</p>
            <h1>Reports</h1>
        </div>
    </header>

    @if (Model?.Feedback is { } feedback)
    {
        var alertClass = feedback.Status switch
        {
            OperationOutcomeStatus.Success => "alert-success",
            OperationOutcomeStatus.PartialSuccess => "alert-warning",
            OperationOutcomeStatus.Empty => "alert-info",
            OperationOutcomeStatus.InvalidRequest => "alert-warning",
            OperationOutcomeStatus.ValidationFailure => "alert-warning",
            _ => "alert-danger"
        };

        <section class="vz-panel">
            <div class="alert @alertClass mb-0" role="status">@feedback.UserMessage</div>
            @if (feedback.Issues.Count > 0)
            {
                <ul class="list-unstyled small mt-2 mb-0">
                    @foreach (var issue in feedback.Issues.Take(5))
                    {
                        <li>@issue.Message</li>
                    }
                </ul>
            }
        </section>
    }

    <div class="row g-3">
        <div class="col-12 col-lg-6">
            <section class="vz-panel h-100">
                <h2 class="h5 mb-2">Export Transactions</h2>
                <p class="text-muted mb-3">
                    Download a CSV file containing your user-scoped transactions for external analysis.
                </p>
                <a asp-controller="Reports" asp-action="ExportTransactionsCsv" class="btn btn-success">
                    Export Transactions CSV
                </a>
            </section>
        </div>

        <div class="col-12 col-lg-6">
            <section class="vz-panel h-100">
                <h2 class="h5 mb-2">Import Transactions</h2>
                <p class="text-muted mb-3">
                    Upload a CSV file containing transaction records.
                </p>

                <form asp-controller="Transactions"
                      asp-action="Import"
                      method="post"
                      enctype="multipart/form-data"
                      class="d-flex flex-column gap-2">
                    <input type="file"
                           name="csvFile"
                           accept=".csv,text/csv"
                           class="form-control"
                           aria-label="Select CSV file to import"
                           required />
                    <div>
                        <button type="submit" class="btn btn-primary">Import Transactions CSV</button>
                    </div>
                </form>
            </section>
        </div>
    </div>

    <section class="vz-panel mt-3">
        <h2 class="h5 mb-2">Analytics Tools</h2>
        <p class="text-muted mb-0">
            Use dashboards and transaction filters to generate category and spending trend reports.
        </p>
    </section>
</section>
