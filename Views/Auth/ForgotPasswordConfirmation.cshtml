@{
    ViewData["Title"] = "Forgot Password";
}

<div class="vz-auth-page">
    <div class="vz-auth-content">
        <section class="vz-auth-state-card">
            <div class="vz-state-icon">M</div>
            <h1 class="vz-state-title">Check your email</h1>
            <p class="vz-state-subtitle">
                If an account exists for that email and email delivery is configured, a password reset link has been sent.
            </p>

            <div class="vz-auth-actions">
                <a asp-action="Login" class="vz-btn-primary">Back to Login</a>
            </div>
        </section>
    </div>
</div>
