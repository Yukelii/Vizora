@model Vizora.Models.LoginViewModel

@{
    ViewData["Title"] = "Sign In";
}

<div class="vz-auth-page">
    <div class="vz-auth-content">
        <section class="vz-auth-card">
            <div class="vz-auth-card-inner">
                <h1 class="vz-auth-heading">Welcome back</h1>
                <p class="vz-auth-subheading">Please enter your details to sign in.</p>

                <form asp-action="Login" method="post" class="vz-auth-form">
                    <div asp-validation-summary="ModelOnly" class="vz-validation-summary"></div>
                    <input type="hidden" asp-for="ReturnUrl" />

                    <div class="vz-auth-field">
                        <label asp-for="UserName" class="vz-auth-label"></label>
                        <input asp-for="UserName" class="vz-auth-input" autocomplete="username" />
                        <span asp-validation-for="UserName" class="vz-auth-validation"></span>
                    </div>

                    <div class="vz-auth-field">
                        <label asp-for="Password" class="vz-auth-label"></label>
                        <input asp-for="Password" class="vz-auth-input" autocomplete="current-password" />
                        <span asp-validation-for="Password" class="vz-auth-validation"></span>
                    </div>

                    <div class="vz-auth-row-between">
                        <label class="vz-auth-check" asp-for="RememberMe">
                            <input asp-for="RememberMe" class="vz-auth-checkbox" />
                            <span>@Html.DisplayNameFor(model => model.RememberMe)</span>
                        </label>
                        <a asp-action="ForgotPassword" class="vz-auth-link">Forgot password?</a>
                    </div>

                    <button type="submit" class="vz-btn-primary">Sign In</button>
                </form>

                <p class="vz-auth-helper">
                    Don't have an account?
                    <a asp-action="Register">Register for an account</a>
                </p>
            </div>
            <div class="vz-auth-card-note">
                <span class="vz-note-dot" aria-hidden="true"></span>
                Secure Enterprise Authentication
            </div>
        </section>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
