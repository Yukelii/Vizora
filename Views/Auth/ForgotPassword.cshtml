@model Vizora.Models.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
}

<div class="vz-auth-page">
    <div class="vz-auth-content">
        <section class="vz-auth-state-card">
            <div class="vz-state-icon">R</div>
            <h1 class="vz-state-title">Forgot Password</h1>
            <p class="vz-state-subtitle">
                No worries. Enter your email and we'll send you a secure reset link.
            </p>

            <form asp-action="ForgotPassword" method="post" class="vz-auth-form">
                <div asp-validation-summary="ModelOnly" class="vz-validation-summary"></div>

                <div class="vz-auth-field">
                    <label asp-for="Email" class="vz-auth-label">Email Address</label>
                    <input asp-for="Email" class="vz-auth-input" autocomplete="email" placeholder="name@company.com" />
                    <span asp-validation-for="Email" class="vz-auth-validation"></span>
                </div>

                <button type="submit" class="vz-btn-primary">Send Reset Link</button>
                <a asp-action="Login" class="vz-btn-link">Back to Login</a>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
