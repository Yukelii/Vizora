@model Vizora.Models.ResetPasswordViewModel

@{
    ViewData["Title"] = "Reset Password";
}

<div class="vz-auth-page">
    <div class="vz-auth-content">
        <section class="vz-auth-state-card">
            <div class="vz-state-icon">L</div>
            <h1 class="vz-state-title">Reset Password</h1>
            <p class="vz-state-subtitle">
                Please choose a strong password that you haven't used before.
            </p>
            <p class="vz-auth-inline-email">Resetting password for <strong>@Model.Email</strong></p>

            <form asp-action="ResetPassword" method="post" class="vz-auth-form">
                <div asp-validation-summary="ModelOnly" class="vz-validation-summary"></div>
                <input asp-for="Token" type="hidden" />
                <input asp-for="Email" type="hidden" />

                <div class="vz-auth-field">
                    <label asp-for="Password" class="vz-auth-label"></label>
                    <input asp-for="Password" class="vz-auth-input" autocomplete="new-password" placeholder="New password" />
                    <span asp-validation-for="Password" class="vz-auth-validation"></span>
                </div>

                <div class="vz-auth-field">
                    <label asp-for="ConfirmPassword" class="vz-auth-label"></label>
                    <input asp-for="ConfirmPassword" class="vz-auth-input" autocomplete="new-password" placeholder="Confirm password" />
                    <span asp-validation-for="ConfirmPassword" class="vz-auth-validation"></span>
                </div>

                <ul class="vz-password-rules">
                    <li>Use at least 8 characters</li>
                    <li>Include upper and lowercase letters when possible</li>
                </ul>

                <button type="submit" class="vz-btn-primary">Update Password</button>
                <a asp-action="Login" class="vz-btn-link">Back to Login</a>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
