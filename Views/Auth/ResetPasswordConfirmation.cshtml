@{
    ViewData["Title"] = "Password Reset";
}

<div class="vz-auth-page">
    <div class="vz-auth-content">
        <section class="vz-auth-state-card">
            <div class="vz-state-icon vz-state-icon-success">OK</div>
            <h1 class="vz-state-title">Password Updated</h1>
            <p class="vz-state-subtitle">
                Your password has been reset successfully.
            </p>

            <div class="vz-auth-actions">
                <a asp-action="Login" class="vz-btn-primary">Sign In</a>
            </div>
        </section>
    </div>
</div>
