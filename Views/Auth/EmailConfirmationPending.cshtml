@{
    ViewData["Title"] = "Check Your Email";
    var statusMessage = ViewData["StatusMessage"]?.ToString();
    var pendingEmail = ViewData["PendingConfirmationEmail"]?.ToString();
}

<div class="vz-auth-page">
    <div class="vz-auth-content">
        <section class="vz-auth-state-card">
            <div class="vz-state-icon">M</div>
            <h1 class="vz-state-title">Check your email</h1>
            <p class="vz-state-subtitle">
                We've sent a confirmation link to
                <strong>@(string.IsNullOrWhiteSpace(pendingEmail) ? "your account email" : pendingEmail)</strong>.
                Please click the link to activate your account.
            </p>

            @if (!string.IsNullOrWhiteSpace(statusMessage))
            {
                <div class="vz-inline-alert vz-inline-alert-info" role="alert">
                    @statusMessage
                </div>
            }

            <form asp-action="ResendConfirmationEmail" method="post" class="vz-auth-actions">
                <button type="submit" class="vz-btn-primary">Resend Email</button>
                <a asp-action="Login" class="vz-btn-link">Back to Login</a>
            </form>
        </section>
    </div>
</div>
