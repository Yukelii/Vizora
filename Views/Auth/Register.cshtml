@model Vizora.Models.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<div class="vz-auth-page">
    <header class="vz-auth-topbar vz-auth-topbar-end">
        <a asp-action="Login" class="vz-auth-top-action">Login</a>
    </header>

    <div class="vz-auth-content">
        <section class="vz-auth-register-shell">
            <div class="vz-auth-register-header">
                <h1 class="vz-auth-heading">Create your account</h1>
                <p class="vz-auth-subheading">
                    Join Vizora to start managing your data securely.
                </p>
                <p class="vz-auth-subheading-note">
                    A confirmation email will be sent to verify your address.
                </p>
            </div>

            <form asp-action="Register" method="post" class="vz-auth-form vz-auth-form-surface">
                <div asp-validation-summary="ModelOnly" class="vz-validation-summary"></div>
                <input type="hidden" asp-for="ReturnUrl" />

                <div class="vz-auth-field">
                    <label asp-for="UserName" class="vz-auth-label"></label>
                    <input asp-for="UserName" class="vz-auth-input" autocomplete="username" />
                    <span asp-validation-for="UserName" class="vz-auth-validation"></span>
                </div>

                <div class="vz-auth-field">
                    <label asp-for="Email" class="vz-auth-label">Email Address</label>
                    <input asp-for="Email" class="vz-auth-input" autocomplete="email" placeholder="name@company.com" />
                    <span asp-validation-for="Email" class="vz-auth-validation"></span>
                </div>

                <div class="vz-auth-password-grid">
                    <div class="vz-auth-field">
                        <label asp-for="Password" class="vz-auth-label"></label>
                        <input asp-for="Password" class="vz-auth-input" autocomplete="new-password" placeholder="Create password" />
                        <span asp-validation-for="Password" class="vz-auth-validation"></span>
                    </div>

                    <div class="vz-auth-field">
                        <label asp-for="ConfirmPassword" class="vz-auth-label"></label>
                        <input asp-for="ConfirmPassword" class="vz-auth-input" autocomplete="new-password" placeholder="Repeat password" />
                        <span asp-validation-for="ConfirmPassword" class="vz-auth-validation"></span>
                    </div>
                </div>

                <label class="vz-auth-check" for="termsAcknowledgement">
                    <input id="termsAcknowledgement" type="checkbox" class="vz-auth-checkbox" />
                    <span>
                        I agree to the
                        <a asp-controller="Home" asp-action="Privacy" class="vz-auth-link">Terms of Service</a>
                        and
                        <a asp-controller="Home" asp-action="Privacy" class="vz-auth-link">Privacy Policy</a>.
                    </span>
                </label>

                <button type="submit" class="vz-btn-primary">Create Account</button>
            </form>

            <p class="vz-auth-helper">
                Already have an account?
                <a asp-action="Login">Sign in</a>
            </p>
        </section>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
