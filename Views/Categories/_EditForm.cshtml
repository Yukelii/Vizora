@model Vizora.Models.CategoryUpsertViewModel
@{
    var isExpenseSelected = Model.Type == TransactionType.Expense;
    var isIncomeSelected = !isExpenseSelected;
    var selectedIconKey = CategoryVisualCatalog.ResolveIconKeyOrDefault(Model.IconKey);
    var iconLibraryModalId = "edit_icon_library_modal";
    var iconLibraryTitleId = "edit_icon_library_title";
    var iconSearchId = "edit_icon_library_search";
}

<form asp-action="Edit" method="post" data-modal-form="edit-category" class="vz-cat-modal-form">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="RowVersion" />
    <input type="hidden" asp-for="ForceOverwrite" />

    <div class="vz-cat-modal-field">
        <label asp-for="Name" class="form-label">Category Name</label>
        <input asp-for="Name" class="form-control" placeholder="e.g. Groceries" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="vz-cat-modal-field">
        <label asp-for="Type" class="form-label">Category Type</label>
        <div class="vz-cat-type-toggle" role="radiogroup" aria-label="Category type">
            <label class="vz-cat-type-option">
                <input class="vz-cat-type-input"
                       type="radio"
                       name="Type"
                       value="@((int)TransactionType.Expense)"
                       checked="@(isExpenseSelected ? "checked" : null)" />
                <span class="vz-cat-type-pill">Expense</span>
            </label>
            <label class="vz-cat-type-option">
                <input class="vz-cat-type-input"
                       type="radio"
                       name="Type"
                       value="@((int)TransactionType.Income)"
                       checked="@(isIncomeSelected ? "checked" : null)" />
                <span class="vz-cat-type-pill">Income</span>
            </label>
        </div>
        <span asp-validation-for="Type" class="text-danger"></span>
    </div>

    <div class="vz-cat-modal-field vz-cat-icon-section">
        <label asp-for="IconKey" class="form-label">Icon</label>
        <input asp-for="IconKey" type="hidden" value="@selectedIconKey" data-vz-icon-value />
        <div class="vz-cat-icon-picker" data-vz-icon-picker>
            <div class="vz-cat-icon-grid" data-vz-icon-grid role="group" aria-label="Category icon quick selection"></div>
            <div class="vz-cat-icon-library-modal"
                 id="@iconLibraryModalId"
                 data-vz-icon-library-modal
                 role="dialog"
                 aria-modal="true"
                 aria-labelledby="@iconLibraryTitleId"
                 hidden>
                <div class="vz-cat-icon-library-backdrop" data-vz-icon-library-close></div>
                <div class="vz-cat-icon-library-panel" role="document">
                    <div class="vz-cat-icon-library-header">
                        <h3 id="@iconLibraryTitleId" class="vz-cat-icon-library-title">Choose an icon</h3>
                        <button type="button"
                                class="vz-cat-icon-library-close"
                                data-vz-icon-library-close
                                aria-label="Close icon library">&times;</button>
                    </div>
                    <div class="vz-cat-icon-library-search-wrap">
                        <label class="visually-hidden" for="@iconSearchId">Search icons</label>
                        <input id="@iconSearchId"
                               class="form-control"
                               type="search"
                               placeholder="Search icons"
                               autocomplete="off"
                               data-vz-icon-search />
                    </div>
                    <div class="vz-cat-icon-library-scroll icon-modal-body">
                        <div class="vz-cat-icon-library-grid icon-grid"
                             data-vz-icon-library-grid
                             role="list"
                             aria-label="Category icon library"></div>
                        <p class="vz-cat-icon-library-empty d-none" data-vz-icon-search-empty>No icons match your search.</p>
                    </div>
                </div>
            </div>
        </div>
        <p class="vz-cat-icon-note">Selected: <span data-vz-selected-icon-label>@CategoryVisualCatalog.GetIconLabel(selectedIconKey)</span></p>
        <span asp-validation-for="IconKey" class="text-danger"></span>
    </div>

    <div class="vz-cat-modal-field">
        <label asp-for="ColorKey" class="form-label">Color</label>
        <div class="vz-cat-color-picker" role="radiogroup" aria-label="Category color selection">
            @foreach (var colorKey in CategoryVisualCatalog.ColorKeys)
            {
                var optionId = $"edit_color_{colorKey}";
                <label class="vz-cat-color-choice" for="@optionId">
                    <input id="@optionId"
                           class="vz-cat-choice-input"
                           type="radio"
                           asp-for="ColorKey"
                           value="@colorKey"
                           aria-label="@CategoryVisualCatalog.GetColorLabel(colorKey)" />
                    <span class="vz-cat-color-option vz-cat-color-@colorKey" aria-hidden="true" title="@CategoryVisualCatalog.GetColorLabel(colorKey)"></span>
                </label>
            }
        </div>
        <span asp-validation-for="ColorKey" class="text-danger"></span>
    </div>

    <div class="d-flex flex-wrap gap-2 justify-content-end vz-cat-modal-actions">
        <a asp-action="Index" class="btn btn-outline-secondary" data-modal-close="true">Cancel</a>
        <button type="submit" class="btn btn-primary">Save Category</button>
    </div>
</form>
