@model Vizora.Models.CategoryUpsertViewModel

@{
    ViewData["Title"] = "Create Category";
    var isModalRequest = string.Equals(
        Context.Request.Headers["X-Requested-With"],
        "XMLHttpRequest",
        StringComparison.OrdinalIgnoreCase);

    if (isModalRequest)
    {
        Layout = null;
    }
}

@if (isModalRequest)
{
    @await Html.PartialAsync(
        "~/Views/Shared/_Modal.cshtml",
        new Dictionary<string, object?>
        {
            ["Size"] = "md",
            ["Variant"] = "form",
            ["BodyPartial"] = "~/Views/Categories/_CreateForm.cshtml",
            ["BodyModel"] = Model,
            ["State"] = ViewData["ModalState"]?.ToString() ?? "idle"
        })
}
else
{
    <h1>Create Category</h1>

    <hr />
    <div class="row">
        <div class="col-md-4">
            <partial name="_CreateForm" model="Model" />
        </div>
    </div>
}
