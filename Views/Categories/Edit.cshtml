@model Vizora.Models.CategoryUpsertViewModel

@{
    ViewData["Title"] = "Edit Category";
    var isModalRequest = string.Equals(
        Context.Request.Headers["X-Requested-With"],
        "XMLHttpRequest",
        StringComparison.OrdinalIgnoreCase);

    if (isModalRequest)
    {
        Layout = null;
    }
}

@if (isModalRequest)
{
    <partial name="_EditForm" model="Model" />
}
else
{
    <h1>Edit Category</h1>

    <hr />
    <div class="row">
        <div class="col-md-4">
            <partial name="_EditForm" model="Model" />
            <div class="mt-3">
                <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
            </div>
        </div>
    </div>
}
