@model Vizora.Models.Category

<div>
    <dl class="row mb-4">
        <dt class="col-sm-4">Name</dt>
        <dd class="col-sm-8">@Model.Name</dd>

        <dt class="col-sm-4">Type</dt>
        <dd class="col-sm-8">@Model.Type</dd>

        <dt class="col-sm-4">Created At</dt>
        <dd class="col-sm-8">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
    </dl>

    <div class="d-flex flex-wrap gap-2">
        <a asp-action="Edit"
           asp-route-id="@Model.Id"
           class="btn btn-primary"
           data-modal="true"
           data-modal-title="Edit Category">Edit</a>
        <button type="button" class="btn btn-outline-secondary" data-modal-close="true">Close</button>
    </div>
</div>
